#!/usr/bin/env sh
# Husky v9+ — pre-commit hook
#
# Three stages, fail-fast:
#   1. gitleaks (#350) — scan staged changes for secrets.
#      Skipped silently if gitleaks is not installed locally
#      (CI still runs it via gitleaks-scan job in .gitlab-ci.yml).
#   2. check-owner-leakage (#494) — scan tracked files for P1–P7 owner-privacy
#      leakage (personal paths, private GitLab host, private slugs, etc.). The
#      scanner reads via `git ls-files`, which sees staged-but-not-committed
#      files — closing the gap where `git add <leak> && git commit` slipped
#      through 3× before (deep-1, deep-2, deep-3). Reuses the same scanner CI
#      runs in the owner-leakage validate job, so local/CI parity is exact.
#   3. lint-staged (#352) — eslint --fix on staged *.mjs.
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact --no-banner --config .gitleaks.toml || {
    echo "✗ gitleaks: secret detected in staged changes. Commit blocked." >&2
    echo "  Use 'git commit --no-verify' to bypass (only after triaging)." >&2
    exit 1
  }
fi

node scripts/lib/validate/check-owner-leakage.mjs "$(git rev-parse --show-toplevel)" >/dev/null 2>&1 || {
  echo "✗ check-owner-leakage: privacy leak detected in tracked files. Commit blocked." >&2
  echo "  Run \`node scripts/lib/validate/check-owner-leakage.mjs .\` for details." >&2
  echo "  Use 'git commit --no-verify' to bypass (only after triaging)." >&2
  exit 1
}

# check-test-fixture-shapes (#556) — scan tracked tests/**/*.{mjs,ts,js} for
# live-credential shapes (sk_live_, xoxb-<digits>, AKIA…, AIzaSy…) that would
# block a public GitHub-mirror push. Uses the same git ls-files enumeration
# pattern as check-owner-leakage, so staged-but-not-committed test fixtures
# are caught before they land on a public branch.
node scripts/lib/validate/check-test-fixture-shapes.mjs "$(git rev-parse --show-toplevel)" >/dev/null 2>&1 || {
  echo "✗ check-test-fixture-shapes: live-credential pattern detected in tests/. Commit blocked." >&2
  echo "  Run \`node scripts/lib/validate/check-test-fixture-shapes.mjs .\` for details." >&2
  echo "  Use \`// @secret-shape-allowed\` magic comment on the fixture file to allowlist intentional cases." >&2
  echo "  Or 'git commit --no-verify' to bypass (only after triaging)." >&2
  exit 1
}

npx lint-staged

# PSA-004 sub-mode B: commit-time wave-scope guard (runs AFTER lint-staged
# re-stages files). See .claude/rules/parallel-sessions.md and #495.
node hooks/wave-scope-commit-guard.mjs || exit 1
