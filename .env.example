# ---------------------------------------------------------------------------
# Session Orchestrator — example environment variables
#
# Copy to `.env` and fill in values as needed. Do NOT commit `.env`.
# ---------------------------------------------------------------------------

# Clank Event Bus webhook URL.
#
# Session Orchestrator fires fire-and-forget POSTs to `${CLANK_EVENT_URL}/api/webhooks/events`
# from `scripts/lib/events.mjs` and `hooks/on-stop.mjs` — but ONLY when
# `CLANK_EVENT_SECRET` is also set. If unset, the default
# `https://events.gotzendorfer.at` (DEFAULT_EVENT_URL in scripts/lib/events.mjs)
# is used.
#
# Production deployments SHOULD set this explicitly rather than relying on the
# built-in default, so the target event bus is obvious from configuration.
# CLANK_EVENT_URL=https://events.gotzendorfer.at

# Bearer token for the Clank Event Bus webhook. When unset, no webhook POST is
# attempted (JSONL event logging still happens locally). Keep this secret.
# CLANK_EVENT_SECRET=
